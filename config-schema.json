{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inspectr.dev/schemas/mcplab/config-schema.json",
  "title": "MCPLab Evaluation Config",
  "description": "Schema for MCPLab evaluation configs using mixed inline/reference lists.",
  "type": "object",
  "additionalProperties": false,
  "required": ["servers", "agents", "scenarios"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Optional display name for this evaluation configuration."
    },
    "servers": {
      "type": "array",
      "description": "Ordered server entries. Each item is either inline server config or a library reference.",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref"],
            "properties": {
              "ref": {
                "type": "string",
                "minLength": 1,
                "description": "Server name from mcplab/servers.yaml"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "transport", "url"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "Inline server id"
              },
              "name": {
                "type": "string",
                "description": "Optional display label"
              },
              "transport": {
                "type": "string",
                "enum": ["http"],
                "description": "MCP transport"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "MCP server URL"
              },
              "auth": {
                "description": "Optional server authentication",
                "oneOf": [
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["type", "env"],
                    "properties": {
                      "type": { "const": "bearer" },
                      "env": { "type": "string", "minLength": 1 }
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["type", "token_url", "client_id_env", "client_secret_env"],
                    "properties": {
                      "type": { "const": "oauth_client_credentials" },
                      "token_url": { "type": "string", "format": "uri" },
                      "client_id_env": { "type": "string", "minLength": 1 },
                      "client_secret_env": { "type": "string", "minLength": 1 },
                      "scope": { "type": "string" },
                      "audience": { "type": "string" },
                      "token_params": {
                        "type": "object",
                        "additionalProperties": { "type": "string" }
                      }
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["type", "client_id", "redirect_url"],
                    "properties": {
                      "type": { "const": "oauth_authorization_code" },
                      "client_id": { "type": "string", "minLength": 1 },
                      "client_secret": { "type": "string" },
                      "redirect_url": { "type": "string", "format": "uri" },
                      "scope": { "type": "string" }
                    }
                  }
                ]
              }
            }
          }
        ]
      }
    },
    "agents": {
      "type": "array",
      "description": "Ordered agent entries. Each item is either inline agent config or a library reference.",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref"],
            "properties": {
              "ref": {
                "type": "string",
                "minLength": 1,
                "description": "Agent name from mcplab/agents.yaml"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "provider", "model"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 },
              "provider": {
                "type": "string",
                "enum": ["openai", "anthropic", "azure_openai"]
              },
              "model": { "type": "string", "minLength": 1 },
              "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
              "max_tokens": { "type": "integer", "minimum": 1, "maximum": 200000 },
              "system": { "type": "string" }
            }
          }
        ]
      }
    },
    "scenarios": {
      "type": "array",
      "description": "Ordered scenario entries. Each item is either inline scenario config or a library reference.",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref"],
            "properties": {
              "ref": {
                "type": "string",
                "minLength": 1,
                "description": "Scenario ID from mcplab/scenarios/*.yaml"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "servers", "prompt"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string" },
              "servers": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "prompt": { "type": "string" },
              "snapshot_eval": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean" },
                  "baseline_snapshot_id": { "type": "string", "minLength": 1 },
                  "baseline_source_run_id": { "type": "string", "minLength": 1 },
                  "last_updated_at": { "type": "string", "format": "date-time" }
                }
              },
              "eval": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "tool_constraints": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "required_tools": {
                        "type": "array",
                        "items": { "type": "string", "minLength": 1 }
                      },
                      "forbidden_tools": {
                        "type": "array",
                        "items": { "type": "string", "minLength": 1 }
                      }
                    }
                  },
                  "tool_sequence": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "allow": {
                        "type": "array",
                        "items": {
                          "type": "array",
                          "items": { "type": "string", "minLength": 1 }
                        }
                      }
                    }
                  },
                  "response_assertions": {
                    "type": "array",
                    "items": {
                      "oneOf": [
                        {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["type", "pattern"],
                          "properties": {
                            "type": { "const": "regex" },
                            "pattern": { "type": "string", "minLength": 1 }
                          }
                        },
                        {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["type", "path"],
                          "properties": {
                            "type": { "const": "jsonpath" },
                            "path": { "type": "string", "minLength": 1 },
                            "equals": {
                              "oneOf": [
                                { "type": "string" },
                                { "type": "number" },
                                { "type": "boolean" }
                              ]
                            }
                          }
                        }
                      ]
                    }
                  }
                }
              },
              "extract": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "from", "regex"],
                  "properties": {
                    "name": { "type": "string", "minLength": 1 },
                    "from": { "const": "final_text" },
                    "regex": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        ]
      }
    },
    "run_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selected_agents": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "snapshot_eval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["warn", "fail_on_drift"] },
        "baseline_snapshot_id": { "type": "string", "minLength": 1 },
        "baseline_source_run_id": { "type": "string", "minLength": 1 },
        "last_updated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
